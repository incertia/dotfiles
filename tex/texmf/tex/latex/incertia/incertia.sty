\ExplSyntaxOn
\str_if_eq:eeTF{\incertia@cat}{bold}{
% cat=bold
\newcommand{\cat}[1]{\textbf{#1}}
}{
\str_if_eq:eeTF{\incertia@cat}{serif}{
% cat=serif
\newcommand{\cat}[1]{\textsf{#1}}
}{
\str_if_eq:eeTF{\incertia@cat}{boldserif}{
% cat=boldserif
\newcommand{\cat}[1]{\textbf{\textsf{#1}}}
}{
% else
\newcommand{\cat}[1]{\textbf{#1}}
\PackageWarning{incertia}{invalid~option~set~for~cat,~defaulting~to~bold
:~\incertia@cat}
}}}
\str_if_eq:eeTF{\incertia@defn}{bold}{
% defn=bold
\newcommand{\defn}[1]{\textbf{#1}}
}{
\str_if_eq:eeTF{\incertia@defn}{italic}{
% defn=italic
\newcommand{\defn}[1]{\textit{#1}}
}{
% else
\newcommand{\defn}[1]{\textbf{#1}}
\PackageWarning{incertia}{invalid~option~set~for~defn,~defaulting~to~bold
:~\incertia@defn}
}}
\ExplSyntaxOff
